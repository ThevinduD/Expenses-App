@{
    ViewData["Title"] = "Home Page";
}

<h2>Dashboard</h2>

<!-- KPI Cards -->
<div class="row mt-4">
    <div class="col-12 col-sm-6 col-lg-4 mb-3">
        <div class="card text-white bg-primary h-100">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div class="w-100">
                    <div class="d-flex justify-content-between align-items-start">
                        <div class="d-flex flex-column">
                            <h5 class="card-title">Today Sales/Returns</h5>
                            <h5 class="card-title">Primary</h5>
                        </div>
                        <a asp-controller="Sales"
                           asp-action="Details"
                           class="btn btn-sm rounded-2 bg-white text-primary"
                           style="font-size: 1.2rem; font-weight: 700; text-decoration:none;">
                            View
                        </a>
                    </div>
                    <p class="mb-0">
                        <span class="kpi-currency text-white">Sales - </span>
                        <span class="card-text kpi-number">@Model.TodayTotalSales.ToString("N0")</span>
                        <span class="kpi-currency">LKR</span>
                    </p>
                    <p class="mb-0">
                        <span class="kpi-currency fw-bold" style="color: #FB7185;">Returns - </span>
                        <span class="card-text kpi-number">@Model.TodayTotalReturns.ToString("N0")</span>
                        <span class="kpi-currency">LKR</span>
                    </p>
                    <p class="mb-0">
                        <span class="kpi-currency text-warning fw-bold">Net - </span>
                        <span class="card-text kpi-number">@Model.TodayNetSales.ToString("N0")</span>
                        <span class="kpi-currency">LKR</span>
                    </p>
                </div>
            </div>

        </div>
    </div>

    <div class="col-12 col-sm-6 col-lg-4 mb-3">
        <div class="card text-white h-100 bg-dark">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div class="w-100">
                    <div class="d-flex justify-content-between align-items-start">
                        <div class="d-flex flex-column">
                            <h5 class="card-title">Non Delivered Inv</h5>
                            <h5 class="card-title">Primary</h5>
                        </div>
                        <a asp-controller="NonDelivered"
                           asp-action="Invoices"
                           class="btn btn-sm rounded-2 bg-white"
                           style="font-size: 1.2rem; font-weight: 700; text-decoration:none; color:#343a40;">
                            View
                        </a>
                    </div>
                    
                    <div class="kpi-container">
                        <h5>Un. 45: </h5>
                        <p class="kpi-number">@Model.NonDeliveredUnder45.ToString("N0")</p>
                        <span class="kpi-currency"> LKR</span>
                    </div>

                    <div class="kpi-container">
                        <h5 class="text-warning fw-bold">Ov. 45: </h5>
                        <p class="kpi-number">@Model.NonDeliveredOver45.ToString("N0")</p>
                        <span class="kpi-currency"> LKR</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-12 col-sm-6 col-lg-4 mb-3">
        <div class="card text-white h-100" style="background-color:#343a40;">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div class="w-100">
                    <div class="d-flex justify-content-between align-items-start">
                        <div class="d-flex flex-column">
                            <h5 class="card-title">Delivered Invoices</h5>
                            <h5 class="card-title">Primary</h5>
                        </div>

                        <a asp-controller="Delivered"
                           asp-action="Invoices"
                           class="btn btn-sm rounded-2 bg-white"
                           style="font-size: 1.2rem; font-weight: 700; text-decoration:none; color:#343a40;">
                            View
                        </a>
                    </div>

                    <p class="card-text kpi-number mb-0">
                        @Model.ThisMonthDeliveredTotal.ToString("N0")
                        <span class="kpi-currency">LKR</span>
                    </p>
                </div>
            </div>
        </div>
    </div>

    <div class="col-12 col-md-6 col-lg-4 mb-3" id="teamWiseSalesContainer">
        <div class="card shadow-sm bg-teal text-white h-100 d-flex align-items-center justify-content-center py-5">
            <div class="spinner-border text-light"></div>
        </div>
    </div>


    <div class="col-md-3 mb-3">
        <div class="card shadow-sm bg-yellow border-0">
            <div class="card-body text-center">

                <div class="fw-bold fs-4 mb-2">Total Stock - Primary</div>

                <table class="table table-borderless table-sm mb-0 mx-auto" style="max-width:420px;">
                    <tbody>
                        <tr>
                            <td class="fw-bold text-start text-warning" style="width:80px; color:#212529 !important">Team</td>
                            <td class="fw-bold text-end text-warning" style="width:150px; color:#212529 !important">Value</td>
                            <td class="fw-bold text-end text-warning" style="width:150px; color:#212529 !important">Expiring&lt;60 </td>
                        </tr>
                        @foreach (var t in Model.TeamStockValues)
                        {
                            <tr>
                                <td class="fw-bold text-start" style="width:70px;">
                                    <a asp-controller="Stock" asp-action="TeamDetails" asp-route-teamCode="@t.TeamCode" asp-route-teamName="@t.TeamName" class="text-white">
                                        @t.TeamName
                                    </a>
                                </td>
                                <td class="fw-bold text-end" style="width:160px;">@t.StockValue.ToString("N0")</td>
                                <td class="fw-bold text-end text-danger" style="width:160px; color:#8b0000 !important;">@t.ExpiringSoonValue.ToString("N0")</td>
                            </tr>
                        }
                        <tr class="border-top">
                            <td class="fw-bold text-start" style="color:#212529 !important">TOTAL</td>
                            <td class="fw-bold text-end">@Model.TotalStockValue.ToString("N0")</td>
                            <td class="fw-bold text-end text-danger" style="color:#8b0000 !important;">
                                @Model.TotalExpiringSoonValue.ToString("N0")
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="col-12 col-md-6 col-lg-4 mb-3" id="topPerformersContainer">
        <div class="card shadow-sm border-0 h-100 d-flex align-items-center justify-content-center py-5" style="background-color: whitesmoke;">
            <div class="spinner-border text-secondary"></div>
        </div>
    </div>


    <div class="col-12 col-sm-6 col-lg-4 mb-3">
        <div class="card text-white h-100" style="background-color: #0d3b66">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <h5 class="card-title">Today Total Sales - RD</h5>
                    <p class="card-text kpi-number mb-0">
                        0
                        <span class="kpi-currency">LKR</span>
                    </p>
                </div>

                <div class="px-4">
                    @* <a asp-controller="Sales"
                       asp-action="Details"
                       class="text-white"
                       style="font-size: 1.3rem; font-weight: 600;">
                        View
                    </a> *@
                </div>
            </div>

        </div>
    </div>


    <div class="col-12 col-sm-6 col-lg-4 mb-3">
        <div class="card text-white bg-success h-100">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <h5 class="card-title">Stock Value - Primary</h5>
                    <p class="card-text kpi-number">
                        <span class="kpi-currency">LKR</span>
                    </p>
                </div>

                <div class="px-4">
                    @* <a asp-controller="Sales"
                       asp-action="Details"
                       class="text-white"
                       style="font-size: 1.3rem; font-weight: 600;">
                        View
                    </a> *@
                </div>
            </div>
        </div>
    </div>

    <div class="col-12 col-sm-6 col-lg-4 mb-3">
        <div class="card text-white h-100" style="background-color: #0f3f22;">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <h5 class="card-title">Stock Value - RD</h5>
                    <p class="card-text kpi-number">0 <span class="kpi-currency">LKR</span></p>
                </div>

                <div class="px-4">
                    @* <a asp-controller="Sales"
                       asp-action="Details"
                       class="text-white"
                       style="font-size: 1.3rem; font-weight: 600;">
                        View
                    </a> *@
                </div>
            </div>
        </div>
    </div>
</div>


@section Scripts {
    <script>
        // Function to fetch the partial view and inject it into the container
        function loadTeamSalesKpi(offset) {
            const container = document.getElementById('teamWiseSalesContainer');

            // THE FIX: Changed 'Dashboard' to 'Home' to match your HomeController
            fetch(`/Home/LoadTeamWiseSalesKpi?monthOffset=${offset}`)
                .then(response => {
                    if (!response.ok) throw new Error("Network response was not ok");
                    return response.text();
                })
                .then(html => {
                    container.innerHTML = html;
                })
                .catch(err => {
                    console.error("Failed to load KPI", err);
                    container.innerHTML = `<div class="text-danger text-center p-3">Failed to load data.</div>`;
                });
        }

        // NEW: Function to load the Top Performers KPI
        function loadTopPerformersKpi(offset, isTop = true) {
            const container = document.getElementById('topPerformersContainer');

            // UPDATED: Attach the isTop value to the URL
            fetch(`/Home/LoadTopPerformersKpi?monthOffset=${offset}&isTop=${isTop}`)
                .then(response => {
                    if (!response.ok) throw new Error("Network response was not ok");
                    return response.text();
                })
                .then(html => {
                    container.innerHTML = html;
                })
                .catch(err => {
                    console.error("Failed to load Top Performers KPI", err);
                    container.innerHTML = `<div class="text-danger text-center p-3">Failed to load data.</div>`;
                });
        }

        // Automatically load the current month (offset 0) when the page loads
        document.addEventListener("DOMContentLoaded", function () {
            loadTeamSalesKpi(0);
            loadTopPerformersKpi(0);
        });
    </script>
}