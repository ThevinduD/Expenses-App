@{
    ViewData["Title"] = "Dashboard";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<style>
    .dashboard-btn {
        min-height: 80px;
        border-radius: 12px;
        font-weight: 600;
        font-size: 0.95rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        border: none;
        color: #fff;
    }

        .dashboard-btn i {
            font-size: 1.5rem;
            margin-bottom: 5px;
        }

    .btn-blue {
        background-color: #0d6efd;
    }

    .btn-green {
        background-color: #198754;
    }

    .btn-teal {
        background-color: #20c997;
    }

    .btn-beige {
        background-color: #d4a373;
    }

    .btn-orange {
        background-color: #fd7e14;
    }

    .btn-lightblue {
        background-color: #0dcaf0;
    }

    .btn-yellow {
        background-color: #ffc107;
        color: #000;
    }

    .btn-pink {
        background-color: #d63384;
    }

    .btn-red {
        background-color: #dc3545;
    }

    .progress-black {
        background-color: #212529;
    }

    .progress-red {
        background-color: #8b0000;
    }

    .progress-purple {
        background-color: #6f42c1;
    }

    .progress-green {
        background-color: #198754;
    }

    .kpi-label {
        font-weight: 600;
        color: #495057;
        font-size: 0.9rem;
    }
</style>

<div class="container-fluid py-3">

    <div class="card shadow-sm mb-4 border-0">
        <div class="card-body bg-light rounded">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="text-muted mb-1">User Detail</h6>
                    <h5 class="mb-0 fw-bold text-dark">
                        @Context.Session.GetString("RealName") -
                        <span class="">@Context.Session.GetString("SalesRepCode")</span>
                    </h5>
                </div>
                <div class="text-end text-muted small">
                    <div id="currentDate" class="fw-bold mb-1"></div>
                    <div id="currentTime"></div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-5 mt-2">
        @* <div class="col-6 col-md-4 col-lg-3">
            <button class="btn dashboard-btn btn-blue w-100 shadow-sm"><i class="bi bi-receipt"></i> Generate Invoice</button>
        </div>
        <div class="col-6 col-md-4 col-lg-3">
            <button class="btn dashboard-btn btn-green w-100 shadow-sm"><i class="bi bi-file-earmark-text"></i> View Invoice</button>
        </div>
        <div class="col-6 col-md-4 col-lg-3">
            <button class="btn dashboard-btn btn-teal w-100 shadow-sm"><i class="bi bi-arrow-return-left"></i> View Return</button>
        </div> *@
        <div class="col-6 col-md-4 col-lg-3">
            <a asp-controller="Itinerary" asp-action="Itinerary" class="btn dashboard-btn btn-blue w-100 shadow-sm text-decoration-none">
                <i class="bi bi-map"></i> Itinerary
            </a>
        </div>
        <div class="col-6 col-md-4 col-lg-3">
            <a asp-controller="Expenses" asp-action="ExpensesEntry" class="btn dashboard-btn btn-green w-100 shadow-sm text-decoration-none">
                <i class="bi bi-wallet2"></i> Expenses Entry
            </a>
        </div>
        @* <div class="col-6 col-md-4 col-lg-3">
            <button class="btn dashboard-btn btn-lightblue w-100 shadow-sm"><i class="bi bi-box-seam"></i> Stock W/ S</button>
        </div>
        <div class="col-6 col-md-4 col-lg-3">
            <button class="btn dashboard-btn btn-blue w-100 shadow-sm"><i class="bi bi-bar-chart-steps"></i> Stock vs Sales</button>
        </div>
        <div class="col-6 col-md-4 col-lg-3">
            <button class="btn dashboard-btn btn-yellow w-100 shadow-sm"><i class="bi bi-info-circle"></i> Sales Info..</button>
        </div> *@
        <div class="col-6 col-md-4 col-lg-3">
            <a asp-controller="DayClose" asp-action="DayClose" class="btn dashboard-btn btn-pink w-100 shadow-sm text-decoration-none">
                <i class="bi bi-moon-stars"></i> Day Close
            </a>
        </div>
        
        <div class="col-6 col-md-4 col-lg-3">
            <form asp-controller="Account" asp-action="Logout" method="post" class="w-100">
                <button type="submit" class="btn dashboard-btn btn-red w-100 shadow-sm"><i class="bi bi-power"></i> Close App</button>
            </form>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-header bg-white border-bottom-0 pt-4 pb-0">
            <h5 class="fw-bold text-dark"><i class="bi bi-graph-up-arrow text-primary"></i> Sales Performance</h5>
        </div>
        <div class="card-body">

            <div class="mb-4">
                <div class="d-flex justify-content-between mb-1">
                    <span class="kpi-label">Sales vs To be Sales</span>
                    <span class="fw-bold">0 / 0</span>
                </div>
                <div class="progress" style="height: 25px;">
                    <div class="progress-bar progress-black" role="progressbar" style="width: 10%" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100">0</div>
                    <div class="progress-bar progress-red w-100 text-end pe-2" role="progressbar" aria-valuenow="100" aria-valuemin="0" aria-valuemax="100">0</div>
                </div>
            </div>

            <div class="mb-4">
                <div class="d-flex justify-content-between mb-1">
                    <span class="kpi-label">Up to Date</span>
                    <span class="fw-bold text-success">0</span>
                </div>
                <div class="progress" style="height: 25px;">
                    <div class="progress-bar progress-green w-100 text-end pe-2" role="progressbar" aria-valuenow="100" aria-valuemin="0" aria-valuemax="100">0</div>
                </div>
            </div>

            <div class="mb-3">
                <div class="d-flex justify-content-between mb-1">
                    <span class="kpi-label">Last Month</span>
                    <span class="fw-bold" style="color: #6f42c1;">0</span>
                </div>
                <div class="progress" style="height: 25px;">
                    <div class="progress-bar progress-purple w-100 text-end pe-2" role="progressbar" aria-valuenow="100" aria-valuemin="0" aria-valuemax="100">0</div>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        function updateDateTime() {
            const now = new Date();

            // Format Date (e.g., May-16-2026)
            const dateOptions = { month: 'short', day: '2-digit', year: 'numeric' };
            const formattedDate = now.toLocaleDateString('en-US', dateOptions).replace(/,/g, '').replace(/ /g, '-');

            // Format Time (e.g., 08:33 AM)
            const timeOptions = { hour: '2-digit', minute: '2-digit' };
            const formattedTime = now.toLocaleTimeString('en-US', timeOptions);

            document.getElementById('currentDate').innerText = formattedDate;
            document.getElementById('currentTime').innerText = formattedTime;
        }

        updateDateTime();
        setInterval(updateDateTime, 1000);
    </script>
}