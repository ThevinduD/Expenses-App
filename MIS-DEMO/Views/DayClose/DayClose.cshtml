@{
    ViewData["Title"] = "Day Close";
}

<style>
    .modern-card {
        border-radius: 16px;
        border: 1px solid rgba(0,0,0,0.05);
        background: #ffffff;
    }

    .bg-soft-light {
        background-color: #f8fafc;
    }

    .form-floating > .form-control {
        border-radius: 10px;
        border-color: #e2e8f0;
    }

        .form-floating > .form-control:focus {
            border-color: #0d6efd;
            box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.15);
        }

    .form-floating > label {
        color: #64748b;
        font-weight: 500;
    }

    .area-list-container {
        max-height: 200px;
        overflow-y: auto;
        border-radius: 10px;
        border: 1px solid #e2e8f0;
        background-color: #f8f9fa;
    }

    .area-list-item {
        border-left: 4px solid transparent;
        transition: all 0.2s;
    }

        .area-list-item:hover {
            background-color: #f1f5f9;
            border-left-color: #0d6efd;
        }

    .section-label {
        font-size: 0.85rem;
        letter-spacing: 0.5px;
        color: #64748b;
    }

    .action-bar {
        position: sticky;
        bottom: 0;
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(10px);
        padding: 15px 0;
        border-top: 1px solid #f1f5f9;
        z-index: 1000;
    }
</style>

<div class="container-fluid pt-3 pb-5 px-3 px-md-4 bg-soft-light min-vh-100">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold text-dark mb-1"><i class="bi bi-moon-stars text-primary"></i>Day Close</h4>
            <p class="text-muted small mb-0">Submit your mileage and visits</p>
        </div>
        <a href="javascript:history.back()" class="btn btn-sm btn-light border shadow-sm rounded-pill px-3 fw-bold text-secondary">
            <i class="bi bi-arrow-left me-1"></i> Back
        </a>
    </div>

    <div class="row justify-content-center">
        <div class="col-12 col-lg-8">
            <div class="card modern-card shadow-sm mb-4">
                <div class="card-body">
                    <form id="dayCloseForm">

                        <div class="row g-3 mb-4 align-items-center">
                            <div class="col-12">
                                <div class="form-floating">
                                    <input type="date" class="form-control fw-bold text-primary w-100" id="closeDate" required onchange="loadItinerary()">
                                    <label for="closeDate">Itinerary Date</label>
                                </div>
                            </div>
                        </div>

                        <hr class="border-light my-4">

                        <div class="mb-4">
                            <label class="form-label fw-bold section-label text-uppercase mb-2">Itinerary Areas</label>
                            <div class="area-list-container p-2" id="areaList">
                                <div class="text-center py-4 text-muted" id="emptyState">
                                    <i class="bi bi-map fs-3 mb-2 d-block text-secondary opacity-50"></i>
                                    <small>Click 'View' to load areas for the selected date.</small>
                                </div>
                                <ul class="list-group list-group-flush d-none" id="loadedAreas">
                                </ul>
                            </div>
                        </div>

                        <h6 class="text-uppercase text-muted fw-bold mb-3 mt-5" style="font-size: 0.8rem; letter-spacing: 0.5px;">Mileage Logs</h6>
                        <div class="row g-3 mb-4">
                            <div class="col-md-4">
                                <div class="form-floating">
                                    <input type="number" class="form-control" id="officialMileage" placeholder="0" step="0.1" min="0">
                                    <label for="officialMileage">Official Mileage</label>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-floating">
                                    <input type="number" class="form-control" id="personalMileage" placeholder="0" step="0.1" min="0">
                                    <label for="personalMileage">Personal Mileage</label>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-floating">
                                    <input type="number" class="form-control bg-light text-primary fw-bold" id="realMileage" placeholder="0" step="0.1" min="0">
                                    <label for="realMileage">Meter Reading</label>
                                </div>
                            </div>
                        </div>

                        <h6 class="text-uppercase text-muted fw-bold mb-3 mt-5" style="font-size: 0.8rem; letter-spacing: 0.5px;">Daily Activity</h6>
                        <div class="row g-3 mb-4">
                            <div class="col-6">
                                <div class="form-floating">
                                    <input type="number" class="form-control" id="doctorVisits" placeholder="0" step="1" min="0">
                                    <label for="doctorVisits">Doctor Visits</label>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="form-floating">
                                    <input type="number" class="form-control" id="pharmacyVisits" placeholder="0" step="1" min="0">
                                    <label for="pharmacyVisits">Pharmacy Visits</label>
                                </div>
                            </div>
                        </div>

                        <div class="mb-2">
                            <div class="form-floating">
                                <textarea class="form-control" id="closingRemark" placeholder="Leave a remark here" style="height: 100px"></textarea>
                                <label for="closingRemark">Remark</label>
                            </div>
                        </div>

                    </form>
                </div>
            </div>
        </div>
    </div>

    <div class="action-bar mt-2">
        <div class="row g-2 justify-content-center">
            <div class="col-12 col-md-4">
                <button type="button" class="btn btn-success w-100 fw-bold shadow-sm py-2" style="border-radius: 12px; font-size: 1.1rem;" onclick="saveDayClose()">
                    <i class="bi bi-floppy me-1"></i> Save Day Close
                </button>
            </div>
            <div class="col-12 col-md-4">
                <a href="javascript:history.back()" class="btn btn-light border text-danger w-100 fw-bold shadow-sm py-2" style="border-radius: 12px; font-size: 1.1rem;">
                    <i class="bi bi-x-circle me-1"></i> Close
                </a>
            </div>
        </div>
    </div>

</div>

@section Scripts {
    <script>
        // Set today's date automatically on load
        document.addEventListener("DOMContentLoaded", function() {
            var dateControl = document.getElementById('closeDate');
            var today = new Date().toISOString().split('T')[0];
            dateControl.value = today;

            // Automatically click the 'View' button to simulate loading today's data
            loadItinerary();
        });

        // Simulate fetching Itinerary Data
        // Real fetching logic
        async function loadItinerary() {
            const dateValue = document.getElementById('closeDate').value;
            const emptyState = document.getElementById('emptyState');
            const loadedAreas = document.getElementById('loadedAreas');

            // 1. Reset UI to loading state
            emptyState.innerHTML = '<div class="spinner-border text-primary spinner-border-sm" role="status"></div> <small class="ms-2">Loading areas...</small>';
            emptyState.classList.remove('d-none');
            loadedAreas.classList.add('d-none');
            loadedAreas.innerHTML = ''; // Clear previous items

            if (!dateValue) return;

            try {
                // 2. Fetch from database
                const response = await fetch(`/DayClose/GetItineraryForDate?date=${dateValue}`);
                const result = await response.json();

                if (result.success) {
                    emptyState.classList.add('d-none');
                    loadedAreas.classList.remove('d-none');

                    // 3. Handle 'Leave' Mode
                    if (result.itineraryType === "Leave") {
                        loadedAreas.innerHTML = `
                            <li class="list-group-item area-list-item bg-transparent d-flex justify-content-between align-items-center">
                                <div><span class="badge bg-danger text-white border me-2">LEAVE</span> <span class="fw-bold">${result.remark}</span></div>
                                <i class="bi bi-house-door-fill text-danger fs-5"></i>
                            </li>
                        `;
                    }
                    // 4. Handle 'Work' Mode
                    else {
                        // Split the remarks by line break (\n) or comma to get individual cities
                        const cities = result.remark.split(/[\n,]+/).map(c => c.trim()).filter(c => c !== "");

                        cities.forEach((city) => {
                            loadedAreas.innerHTML += `
                                <li class="list-group-item area-list-item bg-transparent d-flex justify-content-between align-items-center">
                                    <div class="fw-bold text-dark"><i class="bi bi-geo-alt-fill text-primary me-2"></i> ${city}</div>
                                    <i class="bi bi-check-circle-fill text-success fs-5"></i>
                                </li>
                            `;
                        });
                    }
                } else {
                    // 5. Handle Not Found / Error
                    emptyState.innerHTML = `
                        <i class="bi bi-exclamation-triangle fs-3 mb-2 d-block text-warning opacity-75"></i>
                        <small class="text-danger fw-bold">${result.message}</small>
                    `;
                }
            } catch (error) {
                console.error("Error fetching itinerary:", error);
                emptyState.innerHTML = '<i class="bi bi-x-circle fs-3 mb-2 d-block text-danger opacity-50"></i><small>Error loading data.</small>';
            }
        }

        async function saveDayClose() {
            const formData = new FormData();

            // Gather all input values. Using fallback '0' for empty number fields.
            formData.append("CloseDate", document.getElementById("closeDate").value);
            formData.append("OfficialMileage", document.getElementById("officialMileage").value || 0);
            formData.append("PersonalMileage", document.getElementById("personalMileage").value || 0);
            formData.append("RealMileage", document.getElementById("realMileage").value || 0);
            formData.append("DoctorVisits", document.getElementById("doctorVisits").value || 0);
            formData.append("PharmacyVisits", document.getElementById("pharmacyVisits").value || 0);
            formData.append("Remark", document.getElementById("closingRemark").value.trim());

            try {
                const response = await fetch('/DayClose/SaveDayClose', {
                    method: 'POST',
                    body: formData
                });

                const result = await response.json();

                if (result.success) {
                    alert(result.message);
                    // Clear the form on success
                    document.getElementById("dayCloseForm").reset();
                    document.getElementById('closeDate').value = new Date().toISOString().split('T')[0];
                } else {
                    alert(result.message);
                }
            } catch (error) {
                console.error("Error:", error);
                alert("An error occurred while saving the Day Close record.");
            }
        }
    </script>
}