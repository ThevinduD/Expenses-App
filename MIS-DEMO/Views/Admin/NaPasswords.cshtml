@model List<MIS_DEMO.Models.ViewModels.NaPasswordUserVm>

@{
    ViewData["Title"] = "Users Pending Password";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="fw-bold mb-0">Users with #NA# Password</h4>
</div>

@if (TempData["Msg"] != null)
{
    <div class="alert alert-success py-2">@TempData["Msg"]</div>
}

@if (!Model.Any())
{
    <div class="alert alert-info py-2">No users pending password.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-sm table-striped align-middle">
            <thead class="table-light">
                <tr>
                    <th>UserName</th>
                    <th>Name</th>
                    <th>Email</th>
                    <th style="width:140px;"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var u in Model)
                {
                    <tr>
                        <td class="fw-semibold">@u.UserName</td>
                        <td>@u.Description</td>
                        <td>@u.Email</td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-primary"
                               asp-controller="Admin"
                               asp-action="SetPassword"
                               asp-route-userName="@u.UserName">
                                Set Password
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

