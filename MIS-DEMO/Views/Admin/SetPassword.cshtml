@model MIS_DEMO.Models.ViewModels.SetUserPasswordVm

@{
    ViewData["Title"] = "Set User Password";
}

<div class="mb-3">
    <h4 class="fw-bold mb-0">Set Password</h4>
    <small class="text-muted">User: <span class="fw-semibold">@Model.UserName</span></small>
</div>

<form asp-action="SetPassword" method="post" class="card shadow-sm">
    @Html.AntiForgeryToken()
    <div class="card-body">
        <input type="hidden" asp-for="UserName" />

        <div class="mb-2">
            <label class="form-label small">New Password</label>
            <input asp-for="NewPassword" class="form-control form-control-sm" />
            <span asp-validation-for="NewPassword" class="text-danger small"></span>
        </div>

        <div class="mb-2">
            <label class="form-label small">Confirm Password</label>
            <input asp-for="ConfirmPassword" class="form-control form-control-sm" />
            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
        </div>

        <div class="d-flex gap-2 mt-3">
            <button class="btn btn-sm btn-primary" type="submit">Save</button>
            <a class="btn btn-sm btn-secondary" asp-action="NaPasswords">Back</a>
        </div>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
